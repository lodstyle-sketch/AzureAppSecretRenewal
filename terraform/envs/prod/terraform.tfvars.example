tenant_id                  = "00000000-0000-0000-0000-000000000000"
location                   = "westeurope"
resource_prefix            = "credrenew"
resource_group_name        = "rg-credential-renewal-prod"
internal_api_base_url      = "https://internal-api.example.com"
mail_shared_mailbox        = "credential-renewal@example.com"
department_summary_mailbox = "department@example.com"
webapp_public_base_url     = "https://credential-renewal.example.com"

webapp_zip_path       = "../../../dist/webapp.zip"
automation_wheel_path = "../../../dist/azure_app_credential_renewal-0.1.0-py3-none-any.whl"

enable_cherwell                   = false
enable_graph_app_role_assignments = false

# Enable these only on the Cherwell feature branch.
# cherwell_base_url           = "https://cherwell.example.com/api"
# cherwell_token_url          = "https://cherwell.example.com/token"
# cherwell_client_id          = "credential-renewal"
# cherwell_change_template_id = "standard-change-template"
# cherwell_completed_statuses = "Closed,Completed,Resolved"

tags = {
  environment = "prod"
  workload    = "credential-renewal"
}

# Pass this through a secure CI variable or local environment-specific tfvars file on the Cherwell feature branch.
# cherwell_client_secret = "replace-with-secure-value"
