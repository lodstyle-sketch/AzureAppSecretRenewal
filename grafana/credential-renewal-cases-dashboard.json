{
  "title": "Azure App Credential Renewal Cases",
  "uid": "credential-renewal-cases",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1h",
  "time": { "from": "now-90d", "to": "now" },
  "timezone": "browser",
  "tags": ["azure", "credential-renewal"],
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "grafana-azure-monitor-datasource", "label": "Azure Monitor datasource" },
      { "name": "azureAppName", "type": "textbox", "label": "Azure App Name", "query": "", "current": { "text": "", "value": "" } },
      { "name": "owner", "type": "textbox", "label": "Owner", "query": "", "current": { "text": "", "value": "" } }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Credential Renewal Cases",
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${datasource}" },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${datasource}" },
          "azureLogAnalytics": {
            "resultFormat": "table",
            "query": "CredentialRenewalCases_CL\n| where isempty('$azureAppName') or AzureAppName_s contains '$azureAppName'\n| where isempty('$owner') or OwnersText_s contains '$owner'\n| project TimeGenerated, AzureAppName=AzureAppName_s, OwnerEmails=OwnerEmails_s, CaseState=CaseState_s, CredentialType=CredentialType_s, CredentialExpiresAt=CredentialExpiresAt_t, OldSecretRemovedAt=OldSecretRemovedAt_t\n| order by CredentialExpiresAt asc"
          }
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
