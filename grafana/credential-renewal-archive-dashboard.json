{
  "title": "Credential Renewal Archive",
  "uid": "credential-renewal-archive",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1h",
  "time": { "from": "now-180d", "to": "now" },
  "timezone": "browser",
  "tags": ["azure", "credential-renewal", "archive"],
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "grafana-azure-monitor-datasource", "label": "Azure Monitor datasource" },
      { "name": "azureAppName", "type": "textbox", "label": "Azure App Name", "query": "", "current": { "text": "", "value": "" } },
      { "name": "appId", "type": "textbox", "label": "App ID", "query": "", "current": { "text": "", "value": "" } },
      { "name": "actionOrStatus", "type": "textbox", "label": "Action / Status", "query": "", "current": { "text": "", "value": "" } }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Archive Events",
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${datasource}" },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${datasource}" },
          "azureLogAnalytics": {
            "resultFormat": "table",
            "query": "CredentialRenewalArchive_CL\n| where isempty('$azureAppName') or AzureAppName_s contains '$azureAppName'\n| where isempty('$appId') or AzureAppId_s contains '$appId'\n| where isempty('$actionOrStatus') or Action_s contains '$actionOrStatus' or Status_s contains '$actionOrStatus'\n| project TimeGenerated, AzureAppName=AzureAppName_s, AzureAppId=AzureAppId_s, InternalCode=ServiceManagementReference_s, Action=Action_s, Status=Status_s, Source=Source_s, Actor=Actor_s, CaseId=CaseId_s, CredentialType=CredentialType_s, CredentialKeyId=CredentialKeyId_s\n| order by TimeGenerated desc"
          }
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
